# Production Supabase PostgreSQL connection
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# Production Supabase Configuration
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
# NEVER expose this key in the frontend. It is for API token verification only.
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# API Configuration
PORT=4000
NODE_ENV="production"
FRONTEND_URL="https://your-frontend-domain.com"
RATE_LIMIT_MAX=100
