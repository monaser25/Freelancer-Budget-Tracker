# Public Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."

# Server-side Supabase and Prisma Configuration
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."
CRON_SECRET=""

# Optional external API URL. Leave empty to use same-origin /api routes.
NEXT_PUBLIC_API_URL=""

# Optional local dev auth bypass. Do not enable in Vercel/production.
ENABLE_DEV_AUTH="false"
NEXT_PUBLIC_AUTH_MODE="supabase"

# Optional: emit structured [auth] logs in production to debug live auth
# incidents (login/signup/confirm/reset). Leave "false" normally.
NEXT_PUBLIC_AUTH_DEBUG="false"

# SMTP for sending invoice emails. If unset, the app shows a PDF/mailto fallback
# and never marks invoices as "Sent". See docs/SMTP_EMAIL_SETUP.md.
# Gmail temporary setup: create an App Password (requires 2FA) and use it as SMTP_PASS.
SMTP_HOST=""              # e.g. smtp.gmail.com
SMTP_PORT="587"           # 587 (STARTTLS) or 465 (SSL)
SMTP_SECURE="false"       # "true" only for port 465
SMTP_USER=""              # full email/login, e.g. haseeela@gmail.com
SMTP_PASS=""              # App Password / SMTP password — set in Vercel, never commit
SMTP_FROM=""              # From address, e.g. haseeela@gmail.com
SMTP_FROM_NAME="Haseeela" # Display name on outgoing email
