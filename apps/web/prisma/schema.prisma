// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")

  // Workspace preferences
  currency               String    @default("USD")
  onboardedAt            DateTime?
  notifyBillingReminders Boolean   @default(true)
  notifyInvoiceDue       Boolean   @default(true)
  notifyWeeklySummary    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions         Transaction[]
  budgets              Budget[]
  categories           Category[]
  clients              Client[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  notifications        Notification[]
  auditLogs            AuditLog[]
}

model Client {
  id              String    @id @default(uuid())
  name            String
  email           String?
  company         String?
  revenue         Float     @default(0)
  clientType      String    @default("COMPANY")
  status          String    @default("ACTIVE") // ACTIVE, COMPLETED, PROSPECT, INACTIVE
  paymentType     String    @default("onetime") // onetime, retainer
  paymentDate     DateTime?
  billingDay      Int?
  nextBillingDate DateTime?
  recorded        Boolean   @default(false)
  transactionId   String?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  transactions    Transaction[]
  invoices        Invoice[]

  @@index([userId])
}

model Subscription {
  id              String   @id @default(uuid())
  name            String
  amount          Float
  cycle           String   @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  billingCycle    String   @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  notes           String?
  billingDay      Int      @default(1)
  nextBillingDate DateTime
  status          String   @default("ACTIVE")
  transactionId   String?
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  transactions    Transaction[]

  @@index([userId])
}

model Transaction {
  id         String   @id @default(uuid())
  name       String   @default("")
  amount     Float
  type       String   // "INCOME" or "EXPENSE"
  status     String   @default("COMPLETED") // COMPLETED, PENDING
  date       DateTime
  notes      String?
  sourceType String   // manual, client, subscription
  sourceId   String?
  sourceBillingDate DateTime?
  categoryId String
  isAuto     Boolean  @default(false)
  isEdited   Boolean  @default(false)
   
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([subscriptionId])
  @@index([sourceBillingDate])
  @@unique([userId, sourceType, sourceId, date])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String   // "INCOME" or "EXPENSE"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  budgets      Budget[]
}

model Budget {
  id           String   @id @default(uuid())
  monthlyLimit Float
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id            String   @id @default(uuid())
  number        String
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  issueDate     DateTime
  dueDate       DateTime
  status        String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  currency      String   @default("USD")
  subtotal      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  notes         String?
  terms         String?
  sentAt        DateTime?
  paidAt        DateTime?
  transactionId String?  // linked income transaction when marked paid
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  lineItems     InvoiceLineItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  rate        Float   @default(0)
  amount      Float   @default(0)
  position    Int     @default(0)

  @@index([invoiceId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // BILLING_DUE, INVOICE_OVERDUE, PAYMENT_RECORDED, WEEKLY_SUMMARY, INFO
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  refKey    String?  // dedupe key, e.g. "billing:<subId>:<date>"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, refKey])
  @@index([userId])
  @@index([userId, read])
}
